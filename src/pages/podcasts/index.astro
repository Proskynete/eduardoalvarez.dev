---
import Layout from "../../layouts/main/index.astro";
import { podcasts, topicColors, platformIcons } from "../../settings/podcasts";
import type { PodcastEpisode } from "../../settings/podcasts";
import { Image } from "astro:assets";
import AudioPlayer from "../../components/audio-player/index";
import { faLinkedinIn, faXTwitter } from "@fortawesome/free-brands-svg-icons";

const [liW, liH, , , liPath] = faLinkedinIn.icon;
const [xtW, xtH, , , xtPath] = faXTwitter.icon;

export const prerender = true;

const seo = {
  title: "Podcasts",
  description: "Episodios de podcast donde conversamos sobre desarrollo web, tecnología y carrera profesional.",
  image: "/images/podcasts/podcasts-cover.webp",
};

function formatDuration(minutes: number): string {
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  if (hours > 0) {
    return `${hours}h ${mins}min`;
  }
  return `${mins} min`;
}
---

<Layout seo={seo}>
  <div class="mx-auto max-w-full">
    <!-- Page header -->
    <header class="mb-12">
      <p class="text-text-muted font-mono text-sm">/podcasts</p>
      <h1 class="text-4xl font-bold text-text-primary tracking-tight mb-3">Podcasts</h1>
      <p class="text-text-secondary text-lg">
        Conversaciones sobre desarrollo web, tecnología y carrera profesional con invitados de la industria.
      </p>
    </header>

    <!-- Episodes list -->
    <div class="grid grid-cols-1 gap-6">
      {
        podcasts.map(
          (podcast: PodcastEpisode) =>
            podcast.show && (
              <article class="relative flex flex-col border border-surface-border rounded-xl overflow-hidden hover:border-accent transition-colors duration-200">
                {/* Header del episodio con imagen de fondo */}
                <a
                  href={`/podcasts/${podcast.slug}`}
                  class="relative h-48 md:h-56 overflow-hidden bg-gradient-to-br from-background to-surface block group"
                >
                  {podcast.image && (
                    <Image
                      src={podcast.image}
                      alt={podcast.title}
                      class="w-full h-full object-cover opacity-40 group-hover:opacity-50 transition-opacity duration-200"
                      width={800}
                      height={400}
                      widths={[400, 800]}
                      sizes="(max-width: 768px) 100vw, 800px"
                      format="webp"
                      loading="lazy"
                      decoding="async"
                    />
                  )}

                  {/* Overlay con info principal */}
                  <div class="absolute inset-0 flex flex-col justify-end p-5 bg-gradient-to-t from-black/90 via-black/50 to-transparent">
                    <div class="flex items-center gap-3 mb-2">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-accent/10 text-accent border border-accent/20">
                        Episodio {podcast.episode}
                      </span>
                      <span class="text-sm text-text-secondary">{formatDuration(podcast.duration)}</span>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold text-text-primary line-clamp-2 group-hover:text-accent transition-colors duration-200">
                      {podcast.title}
                    </h2>
                  </div>
                </a>

                {/* Contenido del episodio */}
                <div class="flex flex-col p-5 gap-4">
                  {/* Reproductor de audio */}
                  <AudioPlayer client:visible src={podcast.audioUrl} />

                  {/* Fecha y descripción */}
                  <div class="flex flex-col gap-2">
                    <time datetime={podcast.date} class="text-sm text-text-muted">
                      {new Date(podcast.date).toLocaleDateString("es-ES", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                    <p class="text-text-secondary text-sm line-clamp-3">{podcast.description}</p>
                  </div>

                  {/* Invitados */}
                  {podcast.guests.length > 0 && (
                    <div class="flex flex-col gap-2">
                      <h3 class="text-sm font-semibold text-text-secondary">
                        {podcast.guests.length === 1 ? "Invitado" : "Invitados"}
                      </h3>
                      <div class="flex flex-wrap gap-3">
                        {podcast.guests.map((guest) => (
                          <div class="flex items-center gap-3 bg-surface rounded-lg px-3 py-2">
                            <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-background font-bold text-sm">
                              {guest.name
                                .split(" ")
                                .map((n) => n[0])
                                .join("")
                                .slice(0, 2)}
                            </div>
                            <div class="flex flex-col">
                              <span class="text-sm font-medium text-text-primary">{guest.name}</span>
                              <span class="text-xs text-text-muted">
                                {guest.role}
                                {guest.company && ` @ ${guest.company}`}
                              </span>
                            </div>
                            {/* Links sociales del invitado */}
                            <div class="flex gap-1 ml-2">
                              {guest.linkedin && (
                                <a
                                  href={guest.linkedin}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="p-1 text-text-muted hover:text-accent transition-colors duration-200"
                                  aria-label={`LinkedIn de ${guest.name}`}
                                >
                                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${liW} ${liH}`} fill="currentColor">
                                    <path d={liPath as string} />
                                  </svg>
                                </a>
                              )}
                              {guest.twitter && (
                                <a
                                  href={guest.twitter}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="p-1 text-text-muted hover:text-accent transition-colors duration-200"
                                  aria-label={`Twitter de ${guest.name}`}
                                >
                                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${xtW} ${xtH}`} fill="currentColor">
                                    <path d={xtPath as string} />
                                  </svg>
                                </a>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* Tópicos */}
                  <div class="flex flex-wrap gap-2">
                    {podcast.topics.map((topic) => (
                      <span class={`px-2 py-1 text-xs rounded-md border ${topicColors[topic.color]}`}>
                        {topic.name}
                      </span>
                    ))}
                  </div>

                  {/* Footer: Plataformas + Ver más */}
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-3 border-t border-surface-border">
                    <div class="flex flex-col gap-2">
                      <h3 class="text-sm font-semibold text-text-secondary">Escuchar en</h3>
                      <div class="flex flex-wrap gap-2">
                        {podcast.platforms.map((platform) => (
                          <a
                            href={platform.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-surface hover:bg-surface-raised text-text-secondary hover:text-text-primary transition-colors duration-200"
                            aria-label={`Escuchar en ${platform.name}`}
                          >
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                              <path d={platformIcons[platform.icon]} />
                            </svg>
                            <span class="text-sm">{platform.name}</span>
                          </a>
                        ))}
                      </div>
                    </div>

                    {/* Botón ver episodio completo */}
                    <a
                      href={`/podcasts/${podcast.slug}`}
                      class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-accent hover:bg-accent-hover text-background font-medium transition-colors duration-200"
                    >
                      <span>Ver episodio</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ),
        )
      }
    </div>

    {/* Mensaje si no hay episodios */}
    {
      podcasts.filter((p) => p.show).length === 0 && (
        <div class="text-center py-12">
          <p class="text-text-muted">No hay episodios disponibles en este momento.</p>
          <p class="text-text-muted text-sm mt-2">Vuelve pronto para ver nuevo contenido.</p>
        </div>
      )
    }
  </div>
</Layout>
