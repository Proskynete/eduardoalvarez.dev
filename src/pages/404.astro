---
import Layout from "../layouts/main/index.astro";

export const prerender = true;
---

<Layout>
  <div class="mx-auto max-w-content py-20 text-center">
    <p class="text-accent text-xs font-semibold uppercase tracking-widest mb-4">404</p>
    <h1 class="text-4xl font-bold text-text-primary tracking-tight mb-4">Página no encontrada</h1>
    <p class="text-text-secondary text-lg mb-10">
      Esta página no existe o fue movida. Puede que lo que buscas esté en otro lugar.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 bg-accent text-background text-sm font-semibold rounded-lg hover:bg-accent-hover transition-colors duration-200"
      >
        Inicio
      </a>
      <a
        href="/articles"
        class="px-6 py-3 border border-surface-border text-text-primary text-sm font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
      >
        Ver artículos
      </a>
    </div>
  </div>
</Layout>
