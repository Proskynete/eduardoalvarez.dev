---
import Layout from "../layouts/main/index.astro";

export const prerender = true;

const suggestions = [
  { href: "/", label: "Inicio", description: "Volver a la página principal" },
  { href: "/articles", label: "Artículos", description: "Lecturas sobre ingeniería y liderazgo" },
  { href: "/speaking", label: "Charlas", description: "Charlas y talleres" },
  { href: "/stack", label: "Stack", description: "Herramientas y tecnologías" },
];
---

<Layout>
  <div class="mx-auto max-w-content py-24 flex flex-col items-center text-center">

    <!-- Broken splash animation of the isotipo -->
    <div class="mb-10" aria-hidden="true">
      <div class="crash-container">
        <svg
          width="112"
          height="152"
          viewBox="35 28 320 432"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- ── Phase 1: Diamond + top arrow — draw fully ── -->
          <path
            class="p1"
            d="M194.1,188.1l56.1,56.1l-56.1,56.1l-56.1-56.1L194.1,188.1 M194.1,171.1l-73,73l73,73l73-73L194.1,171.1z"
            fill="none"
            stroke="#06b6d4"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            pathLength="100"
          />
          <polygon
            class="p1"
            fill="none"
            stroke="#06b6d4"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            points="225.7,66.6 192.8,34.1 159.9,66.6 170.7,74.6 170.4,176.3 180.8,165.9 180.8,59.3 204.8,59.3 204.8,165.9 215.2,176.3 214.9,74.6"
            pathLength="100"
          />
          <rect class="p1-detail" fill="none" stroke="#06b6d4" stroke-width="1.5" x="189.2" y="61.8" width="7.5" height="157.6" pathLength="100" />
          <circle class="p1-detail" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="192.9" cy="55.7" r="7.2" pathLength="100" />
          <circle class="p1-detail" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="192.9" cy="225.6" r="7.2" pathLength="100" />
          <circle class="p1-detail" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="134.2" cy="111.6" r="8.3" pathLength="100" />
          <circle class="p1-detail" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="47.7" cy="198" r="8.3" pathLength="100" />

          <!-- ── Phase 2: Bottom arrow — draws ~70%, then crashes ── -->
          <polygon
            class="p2"
            fill="none"
            stroke="#06b6d4"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            points="161.7,422.1 194.5,454.6 227.4,422.1 216.7,414.1 216.9,312.3 206.5,322.7 206.5,429.3 182.6,429.3 182.6,322.7 172.2,312.3 172.4,414.1"
            pathLength="100"
          />
          <rect class="p2" fill="none" stroke="#06b6d4" stroke-width="1.5" x="190.7" y="269.3" transform="matrix(-1 -1.224647e-16 1.224647e-16 -1 388.8 696.1362)" width="7.5" height="157.6" pathLength="100" />
          <circle class="p2" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="194.4" cy="433" r="7.2" pathLength="100" />
          <circle class="p2" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="194.4" cy="263.1" r="7.2" pathLength="100" />
          <circle class="p2" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="253.1" cy="111.6" r="8.3" pathLength="100" />

          <!-- ── Phase 3: Arms — barely start, frozen at crash ── -->
          <rect class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" x="35.4" y="151.1" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -82.1987 108.1233)" width="108" height="4.3" pathLength="100" />
          <rect class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" x="295.8" y="99.3" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -21.1306 255.5546)" width="4.3" height="108" pathLength="100" />
          <rect class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" x="243.9" y="333.2" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -149.8935 308.8899)" width="108" height="4.3" pathLength="100" />
          <rect class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" x="87.3" y="281.4" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -210.9616 161.4586)" width="4.3" height="108" pathLength="100" />
          <circle class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="339.6" cy="198" r="8.3" pathLength="100" />
          <circle class="p3" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="134.2" cy="377.1" r="8.3" pathLength="100" />

          <!-- ── Phase 4: Brackets + remaining circles — never appear ── -->
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="139.8,208.8 150.4,198.6 150.3,169.4 123.3,142.4 115.9,150 139.8,172.3" pathLength="100" />
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="98.3,244.1 120.5,221.9 136.2,220.4 120.5,204.7 81.1,244.1 120.5,283.5 136.2,267.9 120.5,266.3" pathLength="100" />
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="247.5,208.8 236.9,198.6 237.1,169.4 264,142.4 271.5,150 247.5,172.3" pathLength="100" />
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="289,244.1 266.8,221.9 251.1,220.4 266.8,204.7 306.2,244.1 266.8,283.5 251.1,267.9 266.8,266.3" pathLength="100" />
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="139.8,279.8 150.4,290.1 150.3,319.2 123.3,346.2 115.9,338.7 139.8,316.4" pathLength="100" />
          <polygon class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="247.5,279.8 236.9,290.1 237.1,319.2 264,346.2 271.5,338.7 247.5,316.4" pathLength="100" />
          <circle class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="253.1" cy="377.1" r="8.3" pathLength="100" />
          <circle class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="339.6" cy="290.6" r="8.3" pathLength="100" />
          <circle class="p4" fill="none" stroke="#06b6d4" stroke-width="1.5" cx="47.7" cy="290.6" r="8.3" pathLength="100" />
        </svg>
      </div>
    </div>

    <!-- Error label -->
    <p class="text-accent text-xs font-semibold uppercase tracking-widest mb-4">Error 404</p>

    <!-- Heading -->
    <h1 class="text-3xl sm:text-4xl font-bold text-text-primary tracking-tight mb-3">
      Página no encontrada
    </h1>
    <p class="text-text-secondary text-base sm:text-lg mb-12 max-w-sm">
      Esta página no existe o fue movida. Puede que lo que buscas esté en otro lugar.
    </p>

    <!-- Destination grid -->
    <div class="w-full grid grid-cols-2 gap-3">
      {
        suggestions.map(({ href, label, description }) => (
          <a
            href={href}
            class="group p-4 text-left rounded-xl border border-surface-border bg-surface hover:border-accent transition-colors duration-200"
          >
            <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 mb-1">
              {label}
            </p>
            <p class="text-xs text-text-muted leading-relaxed">{description}</p>
          </a>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  /* ── Base: normalize all strokes for dashoffset animation ── */
  .crash-container svg path,
  .crash-container svg polygon,
  .crash-container svg rect,
  .crash-container svg circle {
    stroke-dasharray: 100;
  }

  /* ── Phase 1: Diamond + top arrow — draw completely ──
     Delay 0.3s, duration 0.8s → done at 1.1s            */
  .p1 {
    animation: draw-full 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.3s both;
  }
  .p1-detail {
    stroke-opacity: 0.5;
    animation: draw-full 0.6s ease-out 0.7s both;
  }

  /* ── Phase 2: Bottom arrow — draws ~70%, then crashes ──
     Delay 1.1s, duration 1.0s → crash keyframes at 1.7s  */
  .p2 {
    animation: draw-and-crash 1.0s ease-in-out 1.1s both;
  }

  /* ── Phase 3: Arms — barely start, frozen at crash ──
     Delay 1.6s, duration 0.6s → frozen around 2.1s       */
  .p3 {
    animation: draw-freeze 0.6s ease-out 1.6s both;
  }

  /* ── Phase 4: Brackets — briefly flicker, then gone ──
     Delay 1.82s, duration 0.35s                          */
  .p4 {
    animation: blink-out 0.35s ease-out 1.82s both;
  }

  /* ── Container: shake → dim → broken idle ── */
  .crash-container {
    display: inline-block;
    animation:
      crash-shake 0.25s ease-in-out 1.78s 1 both,
      post-crash  0.45s ease-out    2.05s 1 forwards,
      broken-idle 6s   ease-in-out  2.6s  infinite;
  }

  /* ─────────────────────── Keyframes ─────────────────────── */

  @keyframes draw-full {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes draw-and-crash {
    0%   { stroke-dashoffset: 100; opacity: 1; }
    52%  { stroke-dashoffset: 22;  opacity: 1; }   /* 78% drawn — looking good  */
    60%  { stroke-dashoffset: 40;  opacity: 0.3; } /* CRASH: jump back + flicker */
    66%  { stroke-dashoffset: 24;  opacity: 1; }   /* stutter recovery attempt  */
    73%  { stroke-dashoffset: 56;  opacity: 0.5; } /* hard fail                 */
    100% { stroke-dashoffset: 54;  opacity: 0.6; } /* frozen broken             */
  }

  @keyframes draw-freeze {
    0%   { stroke-dashoffset: 100; opacity: 1; }
    42%  { stroke-dashoffset: 60;  opacity: 1; }    /* 40% drawn                 */
    52%  { stroke-dashoffset: 60;  opacity: 0.1; }  /* blink off at crash        */
    60%  { stroke-dashoffset: 60;  opacity: 0.6; }  /* flash                     */
    70%  { stroke-dashoffset: 60;  opacity: 0.15; } /* off again                 */
    100% { stroke-dashoffset: 63;  opacity: 0.38; } /* barely visible, frozen    */
  }

  @keyframes blink-out {
    0%   { stroke-dashoffset: 100; opacity: 0; }
    35%  { stroke-dashoffset: 88;  opacity: 0.55; } /* briefly appears */
    65%  { stroke-dashoffset: 88;  opacity: 0; }    /* gone            */
    100% { stroke-dashoffset: 100; opacity: 0; }
  }

  @keyframes crash-shake {
    0%   { transform: translate(0, 0)       rotate(0deg);    filter: none; }
    12%  { transform: translate(-8px, 4px)  rotate(-1deg);   filter: brightness(2.5) saturate(0); }
    25%  { transform: translate(9px, -5px)  rotate(0.8deg);  filter: brightness(0.4); }
    38%  { transform: translate(-7px, 6px)  rotate(-0.6deg); filter: brightness(2) hue-rotate(170deg); }
    50%  { transform: translate(8px, -3px)  rotate(0.4deg);  filter: brightness(0.6); }
    62%  { transform: translate(-5px, 5px)  rotate(-0.3deg); filter: brightness(1.5); }
    75%  { transform: translate(5px, -4px)  rotate(0.3deg);  filter: none; }
    88%  { transform: translate(-3px, 2px)  rotate(0deg);    filter: none; }
    100% { transform: translate(2px, 1px)   rotate(0deg);    filter: none; }
  }

  @keyframes post-crash {
    from { filter: none; }
    to   { filter: saturate(0.45) brightness(0.78); }
  }

  /* Rare, irregular flicker — happens late in the 6s cycle */
  @keyframes broken-idle {
    0%,  82%, 87%, 92%, 100% { filter: saturate(0.45) brightness(0.78); }
    84%  { filter: saturate(0.45) brightness(0.4); }  /* dim flash   */
    89%  { filter: saturate(0.45) brightness(0.9); }  /* brief surge */
    94%  { filter: saturate(0.3)  brightness(0.35); } /* deep dim    */
  }

  /* ── Reduced motion: skip directly to broken end state ── */
  @media (prefers-reduced-motion: reduce) {
    .crash-container {
      animation: none;
      transform: translate(2px, 0);
      filter: saturate(0.45) brightness(0.78);
    }
    .p1        { animation: none; stroke-dashoffset: 0; }
    .p1-detail { animation: none; stroke-dashoffset: 0; stroke-opacity: 0.5; }
    .p2        { animation: none; stroke-dashoffset: 54; opacity: 0.6; }
    .p3        { animation: none; stroke-dashoffset: 63; opacity: 0.38; }
    .p4        { animation: none; stroke-dashoffset: 100; opacity: 0; }
  }
</style>
