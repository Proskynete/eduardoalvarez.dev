---
import Layout from "../../layouts/main/index.astro";
import settings from "../../settings";
import { talks } from "../../settings/talks";
import type { Talk } from "../../settings/talks";

export const prerender = true;

const visibleTalks = talks.filter((t: Talk) => t.show);

// Group by year descending
const byYear = visibleTalks.reduce<Record<number, Talk[]>>((acc, talk) => {
  const year = new Date(talk.date[0]).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(talk);
  return acc;
}, {});

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

const eventsSchema = {
  "@context": "https://schema.org",
  "@graph": visibleTalks.map((talk: Talk) => ({
    "@type": "Event",
    name: talk.title,
    startDate: new Date(talk.date[0]).toISOString(),
    ...(talk.description ? { description: talk.description } : {}),
    location: {
      "@type": "Place",
      name: talk.location.name,
      url: talk.location.url,
    },
    organizer: talk.organizations.map((org) => ({
      "@type": "Organization",
      name: org.name,
      url: org.url,
    })),
  })),
};

const seo = {
  title: "Charlas y talleres técnicos",
  description: "Charlas y talleres sobre liderazgo de ingeniería, arquitectura de plataformas y construcción con IA.",
  schema: eventsSchema,
};
---

<Layout seo={seo}>
  <div class="mx-auto max-w-full">
    <!-- Page header -->
    <header class="mb-12">
      <p class="text-text-muted font-mono text-sm">/charlas</p>
      <h1 class="text-4xl font-bold text-text-primary tracking-tight mb-3">Charlas</h1>
      <p class="text-text-secondary text-lg mb-4">
        Charlas y talleres sobre liderazgo de ingeniería, arquitectura de plataformas y construcción con IA.
      </p>
      <p class="text-text-secondary text-base leading-relaxed max-w-3xl mb-4">
        Participo regularmente en conferencias, meetups y workshops privados hablando sobre liderazgo técnico,
        plataformas internas, Developer Experience y el impacto real de la IA en equipos de ingeniería. Los formatos
        incluyen keynotes, charlas de 30-45 minutos, paneles y workshops intensivos presenciales o remotos.
      </p>
      <p class="text-text-secondary text-sm mb-4">
        Me encantaría participar en tu evento. Si quieres que hable, escríbeme a{" "}
        <a href="mailto:soy@eduardoalvarez.dev" class="text-accent underline">Hablemos →</a>
      </p>
      <p class="text-text-muted text-sm">
        {settings.authorInlineBio.text}{" "}
        <a href={settings.authorInlineBio.href} class="text-accent underline">{settings.authorInlineBio.cta}</a>
      </p>
    </header>

    <!-- Talks grouped by year -->
    {years.map((year: number) => (
      <section class="mb-14">
        <h2 class="text-sm font-medium text-text-muted uppercase tracking-widest mb-6 flex items-center gap-3">
          {year}
          <span class="flex-1 h-px bg-surface-border"></span>
        </h2>

        <div class="divide-y divide-surface-border">
          {byYear[year].map((talk: Talk) => (
            <article class="py-6 first:pt-0">
              <div class="flex flex-col gap-3">
                <!-- Title -->
                <h3 class="text-lg font-semibold text-text-primary leading-snug">
                  {talk.title}
                </h3>

                <!-- Meta -->
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-muted">
                  <span>
                    <time datetime={talk.date[0]}>
                      {new Date(talk.date[0]).toLocaleDateString("es-CL", {
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                  </span>
                  <span class="text-surface-border">·</span>
                  <a
                    href={talk.location.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-text-primary transition-colors duration-200"
                  >
                    {talk.location.name}
                  </a>
                </div>

                <!-- Description -->
                {talk.description && (
                  <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">
                    {talk.description}
                  </p>
                )}

                <!-- Resource links -->
                {talk.options && (
                  <div class="flex flex-wrap gap-4 mt-1">
                    {talk.options.presentation && (
                      <a
                        href={talk.options.presentation}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-accent text-sm hover:underline inline-flex items-center gap-1"
                        aria-label={`Ver slides de ${talk.title}`}
                      >
                        Slides ↗
                      </a>
                    )}
                    {talk.options.repo && (
                      <a
                        href={talk.options.repo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-accent text-sm hover:underline inline-flex items-center gap-1"
                        aria-label={`Ver repositorio de ${talk.title}`}
                      >
                        Repo ↗
                      </a>
                    )}
                    {talk.options.resources?.map((r) => (
                      <a
                        href={r.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-accent text-sm hover:underline inline-flex items-center gap-1"
                        aria-label={`${r.label} de ${talk.title}`}
                      >
                        {r.label} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>
