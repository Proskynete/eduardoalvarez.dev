---
import type { Article as IArticle } from "../interfaces";
import Layout from "../layouts/main/index.astro";
import Article from "../components/article/index.astro";
import Subscribe from "../components/subscribe/index.astro";
import { talks } from "../settings/talks";
import type { Talk } from "../settings/talks";
import { articlesSort } from "../utils/articles";

export const prerender = true;

interface Post {
  frontmatter: IArticle;
}

const _MAX_ARTICLES = 3;
const rawPosts = import.meta.glob<{ frontmatter: IArticle }>("./articles/*.mdx", { eager: true });
const posts: Post[] = Object.values(rawPosts);
posts.sort(articlesSort).splice(_MAX_ARTICLES);

const featuredTalks = talks.filter((t: Talk) => t.show).slice(0, 3);

const seo = {
  title: "Eduardo Álvarez — Engineering Leadership & Platform Thinking",
  description: "Engineering Leadership & Platform Thinking in the AI Era.",
};
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="pt-16 pb-20 mb-20 bg-hero-gradient rounded-2xl px-8 sm:px-12">
    <p class="text-accent text-xs font-semibold uppercase tracking-widest mb-5">
      Engineering Leadership & Platform Thinking
    </p>
    <h1 class="text-5xl sm:text-6xl font-bold text-text-primary tracking-tight leading-none mb-6">
      Eduardo<br />Álvarez
    </h1>
    <p class="text-text-secondary text-lg leading-relaxed max-w-lg mb-10">
      Ayudo a equipos de ingeniería a escalar con criterio — desde la arquitectura de plataforma hasta la cultura de
      liderazgo técnico en la era de la IA.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/articles"
        class="px-6 py-3 bg-accent text-background text-sm font-semibold rounded-lg hover:bg-accent-hover transition-colors duration-200"
      >
        Leer artículos
      </a>
      <a
        href="/working-with-me"
        class="px-6 py-3 border border-surface-border text-text-primary text-sm font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
      >
        Trabajar juntos
      </a>
    </div>
  </section>

  <!-- Latest Writing -->
  <section class="mb-20 mx-auto max-w-full">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-text-primary">Últimos artículos</h2>
      <a href="/articles" class="text-accent text-sm hover:underline">Ver todos →</a>
    </div>
    <div class="divide-y divide-surface-border">
      {posts.map(({ frontmatter }) => <Article article={frontmatter} />)}
    </div>
  </section>

  <!-- Recent Speaking -->
  {
    featuredTalks.length > 0 && (
      <section class="mb-20 mx-auto max-w-full">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-text-primary">Charlas recientes</h2>
          <a href="/speaking" class="text-accent text-sm hover:underline">
            Ver todas →
          </a>
        </div>
        <div class="divide-y divide-surface-border">
          {featuredTalks.map((talk: Talk) => (
            <div class="py-6 first:pt-0">
              <div class="flex items-center gap-2 text-xs text-text-muted mb-2">
                <time datetime={talk.date[0]}>
                  {new Date(talk.date[0]).toLocaleDateString("es-CL", { year: "numeric", month: "long" })}
                </time>
                <span class="text-surface-border">·</span>
                <a
                  href={talk.location.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-text-secondary transition-colors duration-200"
                >
                  {talk.location.name}
                </a>
              </div>
              <p class="font-semibold text-text-primary">{talk.title}</p>
              {talk.description && (
                <p class="text-text-secondary text-sm mt-1 leading-relaxed line-clamp-2">{talk.description}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Newsletter CTA -->
  <section class="mx-auto max-w-content bg-surface rounded-xl border border-surface-border p-8 sm:p-10">
    <h2 class="text-xl font-bold text-text-primary mb-1">Newsletter</h2>
    <p class="text-text-secondary text-sm mb-6">
      Artículos sobre liderazgo, plataforma y la era de la IA — directamente en tu correo.
    </p>
    <Subscribe />
  </section>
</Layout>
