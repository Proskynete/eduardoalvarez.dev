---
import Layout from "../../layouts/main/index.astro";
import { experience } from "../../settings/about";
import { nowItems, lastUpdated } from "../../settings/now";
import type { NowItem } from "../../settings/now";
import settings from "../../settings";

export const prerender = true;

const sameAs = [
  ...settings.social_network.filter((s) => s.link).map((s) => s.link),
  ...settings.contacts.filter((c) => c.href && c.href.startsWith("http")).map((c) => c.href),
].filter((url, idx, arr) => arr.indexOf(url) === idx);

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: settings.author.name,
  url: settings.url,
  email: settings.email,
  jobTitle: "Engineering Leader",
  knowsAbout: [
    "Engineering Leadership",
    "Platform Engineering",
    "AI-native Engineering",
    "Technical Leadership",
    "Staff Engineering",
    "Software Architecture",
    "Developer Experience",
  ],
  hasOccupation: {
    "@type": "Role",
    roleName: "Engineering Leader & Platform Thinking",
  },
  sameAs,
};

const seo = {
  title: "Sobre Eduardo Álvarez — Engineering Leader",
  description: "Líder de ingeniería, pensador de plataformas y mentor técnico trabajando en la era de la IA.",
  schema,
};

const nowCategories = [...new Set(nowItems.map((item: NowItem) => item.category))];
const nowByCategory = Object.fromEntries(
  nowCategories.map((cat) => [cat, nowItems.filter((item: NowItem) => item.category === cat)]),
);

const formattedDate = new Date(lastUpdated).toLocaleDateString("es-CL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout seo={seo}>
  <div class="mx-auto max-w-full space-y-16">
    <!-- Hero: texto + foto -->
    <section class="flex flex-col-reverse sm:flex-row items-start gap-10 sm:gap-16">
      <div class="flex-1 space-y-4">
        <p class="text-text-muted font-mono text-sm">/sobre_mi</p>
        <h1 class="text-4xl font-bold text-text-primary tracking-tight leading-tight">
          Hola, soy Eduardo.<br />
          <span class="text-accent">Ingeniero y líder técnico</span><br />
          con más de 10 años construyendo en internet.
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed">
          Trabajo en la intersección de arquitectura de plataforma, liderazgo técnico y los flujos de trabajo que la IA
          está transformando. He pasado por startups y empresas digitales en Chile y Latinoamérica — desde ingeniero
          individual hasta CTO.
        </p>
        <p class="text-text-secondary leading-relaxed">
          Mi foco es transformar equipos desde la entrega de features al pensamiento de plataforma: construir con
          criterio, escalar con intención y liderar con contexto en lugar de control.
        </p>
        <p class="text-text-secondary leading-relaxed">
          Este sitio es donde pienso en voz alta sobre ingeniería. No es un blog de tutoriales — es un espacio para
          ideas con criterio.
        </p>
      </div>

      <div class="w-48 sm:w-64 flex-shrink-0">
        <img
          src="/images/eduardo_alvarez_2.png"
          alt="Eduardo Álvarez"
          width="512"
          height="680"
          class="w-full aspect-[3/4] object-cover object-top rounded-2xl border border-surface-border"
          loading="eager"
        />
      </div>
    </section>

    <!-- En qué trabajo -->
    <section>
      <h2 class="text-2xl font-bold text-text-primary mb-6">En qué trabajo</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl border border-surface-border bg-surface space-y-2">
          <span class="text-accent text-xl">⬡</span>
          <h3 class="font-semibold text-text-primary">Platform Engineering</h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            Plataformas internas que permiten a los equipos moverse más rápido con menos fricción técnica.
          </p>
        </div>
        <div class="p-5 rounded-xl border border-surface-border bg-surface space-y-2">
          <span class="text-accent text-xl">⬡</span>
          <h3 class="font-semibold text-text-primary">Engineering Leadership</h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            Acompañar a managers y tech leads en su evolución hacia un liderazgo con criterio y escala.
          </p>
        </div>
        <div class="p-5 rounded-xl border border-surface-border bg-surface space-y-2">
          <span class="text-accent text-xl">⬡</span>
          <h3 class="font-semibold text-text-primary">AI-native Engineering</h3>
          <p class="text-text-secondary text-sm leading-relaxed">
            Entender cómo los agentes de IA están cambiando los flujos de trabajo y qué significa para los equipos.
          </p>
        </div>
      </div>
    </section>

    <!-- Ahora -->
    <section id="ahora">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl font-bold text-text-primary">Ahora</h2>
        <p class="text-xs text-text-muted">
          Actualizado: {formattedDate} · <a
            href="https://nownownow.com/about"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline">¿Qué es esto?</a
          >
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        {
          nowCategories.map((category) => (
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-accent mb-4">{category}</h3>
              <div class="space-y-4">
                {nowByCategory[category].map((item: NowItem) => (
                  <div class="border-l-2 border-surface-border pl-4 hover:border-accent transition-colors duration-200">
                    <p class="font-semibold text-text-primary text-sm mb-1">{item.label}</p>
                    {item.description && (
                      <p class="text-text-secondary text-sm leading-relaxed">{item.description}</p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Experiencia -->
    <section>
      <h2 class="text-2xl font-bold text-text-primary mb-8">Experiencia</h2>
      <div class="relative">
        <!-- Línea vertical -->
        <div class="absolute left-[7.5rem] top-0 bottom-0 w-px bg-surface-border hidden sm:block"></div>

        <div class="space-y-8">
          {
            experience.map((item) => (
              <div class="flex flex-col sm:flex-row gap-2 sm:gap-8">
                <div class="sm:w-28 flex-shrink-0 flex sm:justify-end items-start pt-0.5">
                  <span class={`font-mono text-xs ${item.current ? "text-accent" : "text-text-muted"}`}>
                    {item.date}
                  </span>
                </div>

                <div class="hidden sm:flex items-start justify-center w-4 flex-shrink-0 pt-1.5">
                  <div
                    class={`w-2 h-2 rounded-full border-2 ${item.current ? "border-accent bg-accent" : "border-surface-border bg-background"}`}
                  />
                </div>

                <div
                  class={`flex-1 pb-8 ${item.current ? "border-l-2 border-accent sm:border-none pl-4 sm:pl-0" : ""}`}
                >
                  <p class={`font-semibold ${item.current ? "text-text-primary" : "text-text-primary"}`}>{item.role}</p>
                  <p class="text-accent text-sm mb-2">{item.company}</p>
                  <p class="text-text-secondary text-sm leading-relaxed">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Cómo pienso -->
    <section>
      <h2 class="text-2xl font-bold text-text-primary mb-6">Cómo pienso</h2>

      <blockquote class="border-l-4 border-accent pl-6 mb-6">
        <p class="text-text-secondary text-lg leading-relaxed italic">
          La complejidad más cara no está en el código — está en los equipos que resuelven con precisión el problema
          equivocado.
        </p>
      </blockquote>

      <p class="text-text-secondary leading-relaxed mb-4">
        Creo en la ingeniería con criterio: no seguir tendencias por inercia, sino entender el costo real de cada
        decisión técnica y organizacional. Creo que la documentación, la cultura de feedback y los sistemas de
        plataforma son multiplicadores de impacto.
      </p>

      <blockquote class="border-l-4 border-accent pl-6 mt-6">
        <p class="text-text-secondary text-lg leading-relaxed italic">
          No es tu trabajo tener las respuestas — es instalar en el equipo el hábito de buscar el contexto que les
          falta antes de decidir.
        </p>
      </blockquote>
    </section>

    <!-- Comunidad -->
    <section>
      <h2 class="text-2xl font-bold text-text-primary mb-4">Comunidad</h2>
      <p class="text-text-secondary leading-relaxed">
        He dado charlas en conferencias técnicas, talleres en instituciones académicas y mentorías a decenas de
        ingenieros en distintos momentos de su carrera. Fui staff volunteer en <strong class="text-text-primary"
          >JSConf Chile</strong
        >, mentor en <strong class="text-text-primary">Laboratoria</strong> y en <strong class="text-text-primary"
          >TechSchool</strong
        >.
      </p>
    </section>

    <!-- CTA contacto -->
    <section class="rounded-2xl border border-surface-border bg-surface p-8 sm:p-10">
      <h2 class="text-2xl font-bold text-text-primary mb-3">¿Hablamos?</h2>
      <p class="text-text-secondary leading-relaxed mb-8 max-w-xl">
        Si estás trabajando en un desafío de plataforma, liderazgo o arquitectura — o simplemente quieres comentar algo
        que leíste aquí — escríbeme.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="mailto:soy@eduardoalvarez.dev"
          class="px-5 py-2.5 bg-accent text-background text-sm font-semibold rounded-lg hover:bg-accent-hover transition-colors duration-200"
        >
          Escríbeme →
        </a>
        <a
          href="/working-with-me"
          class="px-5 py-2.5 border border-surface-border text-text-primary text-sm font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
        >
          Trabajemos
        </a>
        <a
          href="https://www.linkedin.com/in/eduardoalvarezc"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 border border-surface-border text-text-primary text-sm font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
        >
          LinkedIn
        </a>
      </div>
    </section>
  </div>
</Layout>
