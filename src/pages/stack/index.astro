---
import Layout from "../../layouts/main/index.astro";
import { stack } from "../../settings/stack";
import type { StackCategory, StackItem } from "../../settings/stack";

export const prerender = true;

const seo = {
  title: "Stack & Tools",
  description: "The tools, languages, and frameworks I use daily for engineering and leadership work.",
};
---

<Layout seo={seo}>
  <div class="mx-auto max-w-content">
    <!-- Page header -->
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-text-primary tracking-tight mb-3">Stack & Tools</h1>
      <p class="text-text-secondary text-lg">
        The tools, languages, and frameworks I rely on daily. Updated as things change.
      </p>
    </header>

    <!-- Stack categories -->
    <div class="space-y-14">
      {
        stack.map((category: StackCategory) => (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-6 flex items-center gap-3">
              {category.name}
              <span class="flex-1 h-px bg-surface-border" />
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {category.items.map((item: StackItem) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group p-4 rounded-lg border border-surface-border bg-surface hover:border-accent transition-colors duration-200"
                >
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <span class="font-semibold text-text-primary group-hover:text-accent transition-colors duration-200">
                      {item.name}
                    </span>
                    {item.featured && (
                      <span class="px-1.5 py-0.5 text-xs font-medium rounded bg-accent-subtle text-accent flex-shrink-0">
                        daily
                      </span>
                    )}
                  </div>
                  <p class="text-text-muted text-sm leading-relaxed">{item.description}</p>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
