---
import Layout from "../../layouts/main/index.astro";
import { projects } from "../../settings/projects";
import type { Project, ProjectStatus } from "../../settings/projects";

export const prerender = true;

const seo = {
  title: "Projects",
  description: "Open source projects and tools I've built.",
};

const statusLabel: Record<ProjectStatus, string> = {
  active: "Active",
  maintained: "Maintained",
  archived: "Archived",
};

const statusClasses: Record<ProjectStatus, string> = {
  active: "bg-success/10 text-success",
  maintained: "bg-accent-subtle text-accent",
  archived: "bg-surface-raised text-text-muted",
};

const filters: Array<{ label: string; value: string }> = [
  { label: "All", value: "all" },
  { label: "Active", value: "active" },
  { label: "Maintained", value: "maintained" },
  { label: "Archived", value: "archived" },
];
---

<Layout seo={seo}>
  <div class="mx-auto max-w-content">
    <!-- Page header -->
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-text-primary tracking-tight mb-3">Projects</h1>
      <p class="text-text-secondary text-lg">Open source tools and experiments I've built and maintain.</p>
    </header>

    <!-- Status filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="status-filter" role="group" aria-label="Filtrar por estado">
      {
        filters.map((filter, i) => (
          <button
            class:list={[
              "status-btn px-3 py-1.5 text-xs font-medium rounded-full border transition-colors duration-200",
              i === 0
                ? "bg-accent text-background border-accent"
                : "bg-surface text-text-secondary border-surface-border hover:text-text-primary",
            ]}
            data-status={filter.value}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))
      }
    </div>

    <!-- Projects grid -->
    <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        projects.map((project: Project) => (
          <div
            class="project-item group p-5 rounded-xl border border-surface-border bg-surface hover:border-accent transition-colors duration-200"
            data-status={project.status}
          >
            <div class="flex items-start justify-between gap-3 mb-3">
              <h2 class="font-semibold text-text-primary leading-snug">{project.title}</h2>
              <span
                class:list={[
                  "px-2 py-0.5 text-xs font-medium rounded flex-shrink-0",
                  statusClasses[project.status],
                ]}
              >
                {statusLabel[project.status]}
              </span>
            </div>

            <p class="text-text-secondary text-sm leading-relaxed mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.techStack.map((tech) => (
                <span class="px-2 py-0.5 text-xs rounded bg-surface-raised text-text-muted">{tech}</span>
              ))}
            </div>

            <div class="flex gap-4">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent text-sm hover:underline inline-flex items-center gap-1"
                >
                  Ver sitio ↗
                </a>
              )}
              {project.githubLink && (
                <a
                  href={project.githubLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent text-sm hover:underline inline-flex items-center gap-1"
                >
                  GitHub ↗
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <!-- No results -->
    <p id="no-results" class="hidden text-text-muted text-sm py-8">No hay proyectos en este estado.</p>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".status-btn");
  const items = document.querySelectorAll<HTMLElement>(".project-item");
  const noResults = document.getElementById("no-results");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selected = btn.dataset.status ?? "all";

      buttons.forEach((b) => {
        const isActive = b.dataset.status === selected;
        b.setAttribute("aria-pressed", String(isActive));
        b.classList.toggle("bg-accent", isActive);
        b.classList.toggle("text-background", isActive);
        b.classList.toggle("border-accent", isActive);
        b.classList.toggle("bg-surface", !isActive);
        b.classList.toggle("text-text-secondary", !isActive);
        b.classList.toggle("border-surface-border", !isActive);
      });

      let visible = 0;
      items.forEach((item) => {
        const show = selected === "all" || item.dataset.status === selected;
        item.style.display = show ? "" : "none";
        if (show) visible++;
      });

      if (noResults) noResults.classList.toggle("hidden", visible > 0);
    });
  });
</script>
