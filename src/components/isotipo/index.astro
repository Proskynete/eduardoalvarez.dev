---
/**
 * Isotipo EA-01 — dos variantes:
 *   full  → logo completo con todos los elementos del isotipo EA-01 (header desktop, splash)
 *   mark  → solo los dos diamantes concéntricos, reconocible a cualquier tamaño (mobile, footer, favicon)
 */
interface Props {
  variant?: "full" | "mark";
  class?: string;
}

const { variant = "full", class: className = "" } = Astro.props;
---

