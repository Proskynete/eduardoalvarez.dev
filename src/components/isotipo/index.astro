}

<style is:global>
  @keyframes isotipo-breath {
    0%, 100% {
      filter:
        drop-shadow(0 0 6px rgba(6, 182, 212, 0.7))
        drop-shadow(0 0 16px rgba(6, 182, 212, 0.35));
    }
    50% {
      filter:
        drop-shadow(0 0 14px rgba(6, 182, 212, 1))
        drop-shadow(0 0 32px rgba(6, 182, 212, 0.7))
        drop-shadow(0 0 60px rgba(6, 182, 212, 0.35));
    }
  }

  .breath-animation {
    animation: isotipo-breath 3s ease-in-out 1s infinite both;
  }

  /* En hover: detiene la animación y aplica glow máximo */
  .group:hover .breath-animation {
    animation: none;
    filter:
      drop-shadow(0 0 16px rgba(6, 182, 212, 1))
      drop-shadow(0 0 40px rgba(6, 182, 212, 0.8))
      drop-shadow(0 0 70px rgba(6, 182, 212, 0.4));
    transition: filter 0.25s ease-out;
  }
</style>

