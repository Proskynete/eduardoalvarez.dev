---
import type { FAQItem } from "../../interfaces";

export interface Props {
  faq?: FAQItem[];
}

const { faq } = Astro.props;

const hasItems = faq && faq.length > 0;

const schema = hasItems
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }
  : null;
---

{
  hasItems && (
    <section class="mt-12 pt-10 border-t border-surface-border">
      <h2 class="text-2xl font-bold text-text-primary mb-6">Preguntas frecuentes</h2>
      <dl class="space-y-6">
        {faq!.map((item) => (
          <div class="rounded-xl border border-surface-border bg-surface p-5">
            <dt class="font-semibold text-text-primary mb-2">{item.question}</dt>
            <dd class="text-text-secondary text-sm leading-relaxed">{item.answer}</dd>
          </div>
        ))}
      </dl>
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </section>
  )
}
