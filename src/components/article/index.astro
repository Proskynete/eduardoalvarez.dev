---
import type { Article } from "../../interfaces";
import { prettyDate } from "../../utils/date";

export const prerender = true;

export interface Props {
  article: Article;
  showReadingTime?: boolean;
  headingLevel?: 2 | 3;
}

const { article, headingLevel = 3 } = Astro.props;
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<article class="group py-6">
  <a href={`/articles/${article.slug}`} class="block space-y-2">
    <div class="flex items-center gap-3">
      {
        article.categories && article.categories.length > 0 && (
          <span class="text-xs font-medium uppercase tracking-wider text-accent">{article.categories[0]}</span>
        )
      }
      <time datetime={article.date} class="text-xs text-text-muted">
        {prettyDate(article.date)}
      </time>
    </div>

    <Heading
      class="text-xl font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 leading-snug"
    >
      {article.title}
    </Heading>

    <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">
      {article.excerpt}
    </p>
  </a>
</article>
