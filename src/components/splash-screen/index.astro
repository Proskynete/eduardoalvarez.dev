    <!-- Logotype: fades in after the isotipo drawing completes -->
    <div class="splash-logotype">
      <div class="splash-separator"></div>
      <div class="splash-text">
        <span class="splash-name">Eduardo Álvarez</span>
        <span class="splash-tagline">Engineering Leadership · Platform Thinking</span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  #pwa-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #0a0a0a;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #pwa-splash.is-active {
    display: flex;
  }

  .splash-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .splash-logotype {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }

  .splash-separator {
    width: 32px;
    height: 1px;
    background: rgba(6, 182, 212, 0.5);
  }

  .splash-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    text-align: center;
  }

  .splash-name {
    color: #f5f5f5;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .splash-tagline {
    color: #7c7c7c;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  #pwa-splash.is-exit {
    animation: splash-exit 0.5s ease-out forwards;
    pointer-events: none;
  }

  /* ── Diamond starts hidden ── */
  #pwa-splash .p-diamond {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }

  /* ── All other groups start hidden ── */
  #pwa-splash .p-group,
  #pwa-splash .c-group {
    opacity: 0;
  }

  /* ─── Keyframes ─── */

  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes appear {
    to {
      opacity: 1;
    }
  }

  @keyframes glow-on {
    0% {
      filter: drop-shadow(0 0 2px #06b6d4);
    }
    100% {
      filter: drop-shadow(0 0 6px #06b6d4) drop-shadow(0 0 16px rgba(6, 182, 212, 0.6))
        drop-shadow(0 0 32px rgba(6, 182, 212, 0.25));
    }
  }

  @keyframes splash-exit {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  @keyframes logotype-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Animation sequence (class .is-drawing triggers everything) ─── */

  /* 1. Diamond draws */
  #pwa-splash.is-drawing .p-diamond {
    animation: draw 1s ease-in-out 0.1s forwards;
  }

  /* 2. Arrows fade in */
  #pwa-splash.is-drawing .p-arrows {
    animation: appear 0.4s ease-out 1s forwards;
  }

  /* 3. Arms fade in */
  #pwa-splash.is-drawing .p-arms {
    animation: appear 0.4s ease-out 1.4s forwards;
  }

  /* 4. Brackets fade in */
  #pwa-splash.is-drawing .p-brackets {
    animation: appear 0.4s ease-out 1.8s forwards;
  }

  /* 5. Circles pop in */
  #pwa-splash.is-drawing .c-dots {
    animation: appear 0.2s ease-out 2.2s forwards;
  }

  /* 6. Glow intensifies — "powers on" (solo SVG, no el texto) */
  #pwa-splash.is-drawing .splash-inner svg {
    animation: glow-on 0.9s ease-in 2.4s forwards;
  }

  /* 7. Logotype slides up and fades in */
  #pwa-splash.is-drawing .splash-logotype {
    animation: logotype-in 0.5s ease-out 2.8s forwards;
  }
</style>

<script>
  const splash = document.getElementById("pwa-splash");
  if (splash) {
    const isStandalone =
      window.matchMedia("(display-mode: standalone)").matches ||
      (window.navigator as unknown as { standalone?: boolean }).standalone === true;

    const alreadyShown = sessionStorage.getItem("pwa-splash-shown");

    if (isStandalone && !alreadyShown) {
      sessionStorage.setItem("pwa-splash-shown", "true");

      splash.classList.add("is-active");

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          splash.classList.add("is-drawing");
        });
      });

      setTimeout(() => {
        splash.classList.add("is-exit");
        setTimeout(() => splash.remove(), 500);
      }, 3800);
    } else {
      splash.remove();
    }
  }
</script>
