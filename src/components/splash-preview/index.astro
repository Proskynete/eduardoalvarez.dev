---
// Splash Screen Preview — visible on homepage so you can preview the PWA animation
// without having to install the app. Has a replay button to restart the animation.
---

<section class="mb-20">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text-primary">Pantalla de carga</h2>
      <p class="text-text-secondary text-sm mt-1">Previsualización de la animación del splash screen PWA</p>
    </div>
    <button
      id="sp-replay-btn"
      class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-accent border border-accent/30 rounded-lg hover:bg-accent/10 transition-colors duration-200"
      aria-label="Reproducir animación de nuevo"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
      </svg>
      Replay
    </button>
  </div>

  <!-- Preview container -->
  <div
    id="splash-preview"
    class="relative rounded-2xl border border-surface-border overflow-hidden"
    style="background: #0a0a0a; min-height: 360px;"
  >
    <div class="sp-scene absolute inset-0 flex flex-col items-center justify-center gap-7">
      <!-- Same animated SVG as the splash screen (sp- prefixed classes) -->
      <svg
        viewBox="35 28 320 432"
        xmlns="http://www.w3.org/2000/svg"
        width="105"
        height="142"
        aria-hidden="true"
      >
        <style>#splash-preview svg * { vector-effect: non-scaling-stroke; }</style>
        <!-- Diamond (inner + outer) — draws with stroke-dash -->
        <path
          class="sp sp-diamond"
          d="M194.1,188.1l56.1,56.1l-56.1,56.1l-56.1-56.1L194.1,188.1 M194.1,171.1l-73,73l73,73l73-73L194.1,171.1z"
          fill="none" fill-rule="evenodd" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
          pathLength="100"
        />
        <!-- Vertical arrows (top + bottom) — fade in as group -->
        <g class="sp-group sp-arrows">
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="225.7,66.6 192.8,34.1 159.9,66.6 170.7,74.6 170.4,176.3 180.8,165.9 180.8,59.3 204.8,59.3 204.8,165.9 215.2,176.3 214.9,74.6"/>
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="189.2" y="61.8" width="7.5" height="157.6"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="192.9" cy="55.7" r="7.2"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="192.9" cy="225.6" r="7.2"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="161.7,422.1 194.5,454.6 227.4,422.1 216.7,414.1 216.9,312.3 206.5,322.7 206.5,429.3 182.6,429.3 182.6,322.7 172.2,312.3 172.4,414.1"/>
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="190.7" y="269.3" transform="matrix(-1 -1.224647e-16 1.224647e-16 -1 388.8 696.1362)" width="7.5" height="157.6"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="194.4" cy="433" r="7.2"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="194.4" cy="263.1" r="7.2"/>
        </g>
        <!-- Diagonal arms — fade in as group -->
        <g class="sp-group sp-arms">
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="38.4" y="154.2" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -83.4618 111.1727)" width="108" height="4.3"/>
          <rect fill="none" stroke="#06b6d4" stroke-width="1.5" x="35.4" y="151.1" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -82.1987 108.1233)" width="108" height="4.3"/>
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="292.7" y="102.3" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -24.18 254.2915)" width="4.3" height="108"/>
          <rect fill="none" stroke="#06b6d4" stroke-width="1.5" x="295.8" y="99.3" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -21.1306 255.5546)" width="4.3" height="108"/>
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="240.8" y="330.2" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -148.6304 305.8405)" width="108" height="4.3"/>
          <rect fill="none" stroke="#06b6d4" stroke-width="1.5" x="243.9" y="333.2" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -149.8935 308.8899)" width="108" height="4.3"/>
          <rect fill="none" stroke="#ffffff" stroke-width="1.5" x="90.3" y="278.3" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -207.9122 162.7217)" width="4.3" height="108"/>
          <rect fill="none" stroke="#06b6d4" stroke-width="1.5" x="87.3" y="281.4" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -210.9616 161.4586)" width="4.3" height="108"/>
        </g>
        <!-- Corner brackets — fade in as group -->
        <g class="sp-group sp-brackets">
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="139.8,208.8 150.4,198.6 150.3,169.4 123.3,142.4 115.9,150 139.8,172.3"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="98.3,244.1 120.5,221.9 136.2,220.4 120.5,204.7 81.1,244.1 120.5,283.5 136.2,267.9 120.5,266.3"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="247.5,208.8 236.9,198.6 237.1,169.4 264,142.4 271.5,150 247.5,172.3"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="289,244.1 266.8,221.9 251.1,220.4 266.8,204.7 306.2,244.1 266.8,283.5 251.1,267.9 266.8,266.3"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="139.8,279.8 150.4,290.1 150.3,319.2 123.3,346.2 115.9,338.7 139.8,316.4"/>
          <polygon fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="247.5,279.8 236.9,290.1 237.1,319.2 264,346.2 271.5,338.7 247.5,316.4"/>
        </g>
        <!-- Endpoint circles — pop in last -->
        <g class="sc-group sc-dots">
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="134.2" cy="111.6" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="47.7" cy="198" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="253.1" cy="111.6" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="339.6" cy="198" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="253.1" cy="377.1" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="339.6" cy="290.6" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="134.2" cy="377.1" r="8.3"/>
          <circle fill="none" stroke="#ffffff" stroke-width="1.5" cx="47.7" cy="290.6" r="8.3"/>
        </g>
      </svg>

      <!-- Logotype -->
      <div class="sp-logotype">
        <div class="sp-separator"></div>
        <div class="sp-text">
          <span class="sp-name">Eduardo Álvarez</span>
          <span class="sp-tagline">Engineering Leadership · Platform Thinking</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* ── Diamond starts hidden ── */
  #splash-preview .sp-diamond {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }

  /* ── All other groups start hidden ── */
  #splash-preview .sp-group,
  #splash-preview .sc-group {
    opacity: 0;
  }

  /* ── Logotype starts hidden ── */
  #splash-preview .sp-logotype {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }
  #splash-preview .sp-separator {
    width: 32px;
    height: 1px;
    background: rgba(6, 182, 212, 0.5);
  }
  #splash-preview .sp-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    text-align: center;
  }
  #splash-preview .sp-name {
    color: #f5f5f5;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  #splash-preview .sp-tagline {
    color: #7c7c7c;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ── Keyframes (prefixed sp- to avoid conflicts with #pwa-splash) ── */
  @keyframes sp-draw   { to { stroke-dashoffset: 0; } }
  @keyframes sp-appear { to { opacity: 1; } }

  @keyframes sp-glow-on {
    0%   { filter: drop-shadow(0 0 2px #06b6d4); }
    100% {
      filter:
        drop-shadow(0 0 6px #06b6d4)
        drop-shadow(0 0 16px rgba(6, 182, 212, 0.6))
        drop-shadow(0 0 32px rgba(6, 182, 212, 0.25));
    }
  }

  @keyframes sp-logotype-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes sp-fill-cyan {
    from { fill: transparent; }
    to   { fill: rgba(6, 182, 212, 0.15); }
  }

  @keyframes sp-fill-white {
    from { fill: transparent; }
    to   { fill: rgba(255, 255, 255, 0.08); }
  }

  /* ── Animation sequence — triggered by .sp-is-playing on #splash-preview ── */

  /* 1. Diamond draws */
  #splash-preview.sp-is-playing .sp-diamond {
    animation:
      sp-draw 1.0s ease-in-out 0.1s forwards,
      sp-fill-cyan 0.9s ease-in 2.4s forwards;
  }

  /* 2. Arrows fade in */
  #splash-preview.sp-is-playing .sp-arrows {
    animation: sp-appear 0.4s ease-out 1.0s forwards;
  }

  /* 3. Arms fade in */
  #splash-preview.sp-is-playing .sp-arms {
    animation: sp-appear 0.4s ease-out 1.4s forwards;
  }

  /* 4. Brackets fade in */
  #splash-preview.sp-is-playing .sp-brackets {
    animation: sp-appear 0.4s ease-out 1.8s forwards;
  }

  /* 5. Circles pop in */
  #splash-preview.sp-is-playing .sc-dots {
    animation: sp-appear 0.2s ease-out 2.2s forwards;
  }

  /* 6. Glow — solo al SVG, para que el texto no reciba el drop-shadow */
  #splash-preview.sp-is-playing .sp-scene svg {
    animation: sp-glow-on 0.9s ease-in 2.4s forwards;
  }

  /* 7. Logotype */
  #splash-preview.sp-is-playing .sp-logotype {
    animation: sp-logotype-in 0.5s ease-out 2.8s forwards;
  }

  /* 8. Fill — elementos cyan se llenan con su stroke al mismo tiempo que el glow */
  #splash-preview.sp-is-playing .sp-arrows [stroke="#06b6d4"],
  #splash-preview.sp-is-playing .sp-arms [stroke="#06b6d4"],
  #splash-preview.sp-is-playing .sp-brackets [stroke="#06b6d4"] {
    animation: sp-fill-cyan 0.9s ease-in 2.4s forwards;
  }

  /* 9. Fill — elementos blancos se llenan con su stroke al mismo tiempo que el glow */
  #splash-preview.sp-is-playing .sp-arrows [stroke="#ffffff"],
  #splash-preview.sp-is-playing .sp-arms [stroke="#ffffff"],
  #splash-preview.sp-is-playing .sc-dots [stroke="#ffffff"] {
    animation: sp-fill-white 0.9s ease-in 2.4s forwards;
  }
</style>

<script>
  const preview = document.getElementById("splash-preview");
  const replayBtn = document.getElementById("sp-replay-btn");

  function playAnimation() {
    if (!preview) return;
    // Remove class, force reflow to restart CSS animations, then re-add
    preview.classList.remove("sp-is-playing");
    void (preview as HTMLElement).offsetWidth;
    preview.classList.add("sp-is-playing");
  }

  // Auto-play on load
  document.addEventListener("astro:page-load", () => {
    if (document.getElementById("splash-preview")) {
      playAnimation();
    }
  });

  replayBtn?.addEventListener("click", playAnimation);
</script>
