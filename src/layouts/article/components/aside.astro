---
import { Icon } from "../../../assets/icons";
import type { CategoryAllowed, TagsAllowed } from "../../../interfaces";
import { CategoryMap, TagMap } from "../../../utils/categories";

const { content, timeToRead, toShare } = Astro.props;
const prettyTimeToReadText = timeToRead <= 1 ? "minuto" : "minutos";
---

<aside class="xl:sticky xl:top-24 xl:self-start mb-10 xl:mb-0">
  <div class="text-sm divide-y divide-surface-border">
    <!-- Reading time -->
    <div class="pb-4">
      <p class="mb-1 text-xs font-medium uppercase tracking-widest text-text-muted">Lectura</p>
      <p class="text-text-secondary">{timeToRead} {prettyTimeToReadText}</p>
    </div>

    <!-- Categories -->
    <div class="py-4">
      <p class="mb-2 text-xs font-medium uppercase tracking-widest text-text-muted">Categorías</p>
      <div class="flex flex-col gap-1">
        {
          content.categories.map((category: CategoryAllowed) => (
            <span class="text-text-secondary">{CategoryMap.get(category) ?? category}</span>
          ))
        }
      </div>
    </div>

    <!-- Tags -->
    {
      content.tags && content.tags.length > 0 && (
        <div class="py-4">
          <p class="mb-2 text-xs font-medium uppercase tracking-widest text-text-muted">Tags</p>
          <div class="flex flex-col gap-1">
            {content.tags.map((tag: TagsAllowed) => (
              <span class="text-text-secondary">{TagMap.get(tag) ?? tag}</span>
            ))}
          </div>
        </div>
      )
    }

    <!-- Table of contents (desktop only) -->
    {
      content.sections && content.sections.length > 0 && (
        <div class="hidden xl:block py-4">
          <p class="mb-2 text-xs font-medium uppercase tracking-widest text-text-muted">Secciones</p>
          <nav class="flex flex-col gap-0.5">
            {content.sections.map((section: { anchor: string; title: string }) => (
              <a
                href={`#${section.anchor}`}
                class="py-0.5 text-text-secondary hover:text-accent transition-colors duration-200 border-l-2 border-transparent hover:border-accent pl-2"
              >
                {section.title}
              </a>
            ))}
          </nav>
        </div>
      )
    }

    <!-- Share -->
    <div class="py-4">
      <a
        href={toShare}
        target="_blank"
        rel="nofollow noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-accent hover:underline transition-colors duration-200"
      >
        Compartir en Twitter ↗
      </a>
    </div>

    <!-- Back to articles -->
    <div class="pt-4">
      <a
        href="/articles"
        class="flex items-center gap-1 text-text-secondary hover:text-accent transition-colors duration-200"
        aria-label="Volver a artículos"
      >
        <Icon.ArrowLeft width={16} /> Artículos
      </a>
    </div>
  </div>
</aside>
