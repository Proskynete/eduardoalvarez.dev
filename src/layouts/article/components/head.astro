---
import { Icon } from "../../../assets/icons";
import type { CategoryAllowed } from "../../../interfaces";
import { CategoryMap } from "../../../utils/categories";
import { githubArticlePath } from "../../../utils/articles";
import { prettyDate } from "../../../utils/date";

const { content } = Astro.props;
---

<header class="pb-10 border-b border-surface-border">
  <!-- Category badges -->
  {
    content.categories && content.categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-5">
        {content.categories.map((category: CategoryAllowed) => (
          <span class="px-2.5 py-0.5 text-xs font-medium rounded bg-accent-subtle text-accent uppercase tracking-wider">
            {CategoryMap.get(category) ?? category}
          </span>
        ))}
      </div>
    )
  }

  <!-- Title -->
  <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text-primary leading-tight tracking-tight mb-5">
    {content.title}
  </h1>

  <!-- Meta -->
  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-muted">
    <time datetime={content.date}>
      {prettyDate(content.date)}
    </time>
    <span class="text-surface-border">·</span>
    <a
      class="flex items-center gap-1 text-accent hover:underline transition-colors duration-200"
      href={githubArticlePath(content.slug)}
      target="_blank"
      rel="noopener noreferrer"
    >
      ¿Ves una errata? Edita en GitHub
      <Icon.GitHub />
    </a>
  </div>
</header>
