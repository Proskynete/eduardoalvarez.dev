---
import "../../assets/styles/base.css";

import { ClientRouter } from "astro:transitions";
import BaseHead, { type Props as BaseHeadProps } from "./components/head.astro";
import Footer from "./components/footer/index.astro";
import Header from "./components/header/index.astro";
import ScrollingProgressBar from "../../components/scrolling-progress-bar/index";
import SplashScreen from "../../components/splash-screen/index.astro";

import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
  seo?: BaseHeadProps;
}

// Usar Search-Only API Key para el cliente (solo lectura)
const algolia = {
  ALGOLIA_SEARCH_API_KEY: import.meta.env.PUBLIC_ALGOLIA_SEARCH_API_KEY,
  ALGOLIA_APPLICATION_ID: import.meta.env.PUBLIC_ALGOLIA_APPLICATION_ID,
  ALGOLIA_INDEX_NAME: import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME,
} as const;

const { seo } = Astro.props;
---

<html lang="es-ES">
  <BaseHead {...seo} />

  <ClientRouter />

  <body class="antialiased bg-background text-text-primary">
    <SplashScreen />

    <!-- Skip Navigation Links -->
    <a href="#main-content" class="skip-to-content">Saltar al contenido principal</a>

    <ScrollingProgressBar client:visible />

    <Header algolia={algolia} />

    <div class="mx-auto max-w-full px-4 sm:px-6 xl:px-8">
      <div class="mx-auto max-w-wide">
        <main id="main-content" tabindex="-1" class="mb-auto py-12">
          <slot />
        </main>

        <Footer />
      </div>
    </div>

    <SpeedInsights />
  </body>
</html>
