---
import { Icon } from "../../../../assets/icons";

const currentYear = new Date().getFullYear();
---

<footer id="site-footer" class="mt-20 border-t border-surface-border pt-10 pb-12">
  <div class="flex flex-col sm:flex-row items-center sm:justify-between gap-4">
    <nav aria-label="Social media links" class="flex items-center gap-5">
      <!-- GitHub -->
      <a
        href="https://github.com/Proskynete"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.GitHub />
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/eduardoalvarezc/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.LinkedIn />
      </a>

      <!-- Twitter/X -->
      <a
        href="https://twitter.com/proskynete"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter / X"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.X />
      </a>

      <!-- Instagram -->
      <a
        href="https://www.instagram.com/eduardoalvarez.dev"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.Instagram />
      </a>

      <!-- RSS -->
      <a
        href="/rss.xml"
        aria-label="RSS Feed"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.RSS />
      </a>

      <!-- Email -->
      <a
        href="mailto:soy@eduardoalvarez.dev"
        aria-label="Email"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.Mail />
      </a>

      <!-- Newsletter -->
      <a
        href="/newsletter"
        aria-label="Newsletter"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <Icon.Newsletter />
      </a>
    </nav>

    <!-- Copyright -->
    <pre
      class="font-mono text-xs text-text-muted text-center sm:text-right">$ cd ~/<a href="https://eduardoalvarez.dev" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">eduardoalvarez.dev</a>/{currentYear}<span class="w-0.5 h-3 inline-block bg-accent ml-1 rounded-sm animate-cursor-ping" /></pre>
  </div>
</footer>
