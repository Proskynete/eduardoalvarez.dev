---
import { faGithub, faLinkedinIn, faXTwitter, faInstagram } from "@fortawesome/free-brands-svg-icons";
import { faRss, faEnvelope, faBell } from "@fortawesome/free-solid-svg-icons";

const [ghW, ghH, , , ghPath] = faGithub.icon;
const [liW, liH, , , liPath] = faLinkedinIn.icon;
const [xtW, xtH, , , xtPath] = faXTwitter.icon;
const [igW, igH, , , igPath] = faInstagram.icon;
const [rssW, rssH, , , rssPath] = faRss.icon;
const [envW, envH, , , envPath] = faEnvelope.icon;
const [bellW, bellH, , , bellPath] = faBell.icon;

const currentYear = new Date().getFullYear();
---

<footer id="site-footer" class="mt-20 border-t border-surface-border pt-10 pb-12">
  <div class="flex flex-col sm:flex-row items-center sm:justify-between gap-4">
    <!-- Social links -->
    <nav aria-label="Social media links" class="flex items-center gap-5">
      <a
        href="https://github.com/Proskynete"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${ghW} ${ghH}`} fill="currentColor" class="w-4 h-4">
          <path d={ghPath as string} />
        </svg>
      </a>

      <a
        href="https://www.linkedin.com/in/eduardoalvarezc/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${liW} ${liH}`} fill="currentColor" class="w-4 h-4">
          <path d={liPath as string} />
        </svg>
      </a>

      <a
        href="https://twitter.com/proskynete"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter / X"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${xtW} ${xtH}`} fill="currentColor" class="w-4 h-4">
          <path d={xtPath as string} />
        </svg>
      </a>

      <a
        href="https://www.instagram.com/eduardoalvarez.dev"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${igW} ${igH}`} fill="currentColor" class="w-4 h-4">
          <path d={igPath as string} />
        </svg>
      </a>

      <a
        href="/rss.xml"
        aria-label="RSS Feed"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${rssW} ${rssH}`} fill="currentColor" class="w-4 h-4">
          <path d={rssPath as string} />
        </svg>
      </a>

      <a
        href="mailto:soy@eduardoalvarez.dev"
        aria-label="Email"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${envW} ${envH}`} fill="currentColor" class="w-4 h-4">
          <path d={envPath as string} />
        </svg>
      </a>

      <a
        href="/newsletter"
        aria-label="Newsletter"
        class="text-text-muted hover:text-text-primary transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox={`0 0 ${bellW} ${bellH}`} fill="currentColor" class="w-4 h-4">
          <path d={bellPath as string} />
        </svg>
      </a>
    </nav>

    <!-- Copyright -->
    <pre
      class="font-mono text-xs text-text-muted text-center sm:text-right">$ cd ~/<a href="https://eduardoalvarez.dev" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">eduardoalvarez.dev</a>/{currentYear}<span class="w-0.5 h-3 inline-block bg-accent ml-1 rounded-sm animate-cursor-ping" /></pre>
  </div>
</footer>
