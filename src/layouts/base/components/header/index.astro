---
import pkg from "../../../../../package.json";
import Isotipo from "../../../../components/isotipo/index.astro";
import MobileNav from "./components/mobile";
import Navigation from "./components/navigation";

interface Props {
  algolia?: {
    ALGOLIA_APPLICATION_ID?: string;
    ALGOLIA_INDEX_NAME?: string;
    ALGOLIA_SEARCH_API_KEY?: string;
  };
}

const { algolia } = Astro.props;
---

<header
  class="sticky top-0 z-50 h-nav-height bg-surface border-b border-surface-border transition-all duration-200"
  id="site-header"
>
  <div class="max-w-screen-2xl mx-auto h-full px-4 sm:px-6 xl:px-8 flex items-center justify-between">
    <div role="banner">
      <a href="/" aria-label="Eduardo Álvarez — Ir al inicio" class="flex items-center gap-3 group">
        <!-- Mobile: solo diamantes (reconocible a cualquier tamaño) -->
        <Isotipo
          variant="mark"
          class="h-9 w-auto flex-shrink-0 sm:hidden transition-[filter] duration-300 group-hover:[filter:drop-shadow(0_0_8px_rgba(6,182,212,0.55))]"
        />
        <!-- Desktop: isotipo completo EA-01 -->
        <Isotipo
          variant="full"
          class="h-9 w-auto flex-shrink-0 hidden sm:block transition-[filter] duration-300 group-hover:[filter:drop-shadow(0_0_8px_rgba(6,182,212,0.55))]"
        />

        <!-- Separator -->
        <div class="h-8 w-px bg-accent opacity-50 flex-shrink-0"></div>

        <!-- Logotype -->
        <div class="flex flex-col leading-tight">
          <span
            class="text-text-primary font-bold text-base tracking-tight group-hover:text-accent transition-colors duration-200"
          >
            Eduardo Álvarez
          </span>
          <span class="text-text-muted text-[10px] uppercase tracking-widest hidden sm:block">
            Engineering Leadership · Platform Thinking
          </span>
        </div>
      </a>
    </div>

    <div class="flex items-center gap-4">
      <Navigation client:load pathname={Astro.url.pathname} algolia={algolia} />
      <MobileNav client:visible version={pkg.version} />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener(
      "scroll",
      () => {
        if (window.scrollY > 0) {
          header.classList.add("backdrop-blur-sm");
        } else {
          header.classList.remove("backdrop-blur-sm");
        }
      },
      { passive: true },
    );
  }
</script>
